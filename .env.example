# Council of Experts — environment configuration.
# Copy to `.env` (which is gitignored) and adjust as needed.

# --- Local council (no costs, no API keys) -----------------------------------

# Ollama HTTP endpoint. Default is the local daemon on this Mac.
# Only change if running Ollama on a different host (e.g. a Studio over LAN).
OLLAMA_HOST=http://localhost:11434

# Inter-agent pause in seconds. Thermal-aware execution policy for the
# fanless M5 Air. Increase if asitop shows sustained thermal pressure during
# long multi-agent runs.
COUNCIL_AGENT_PAUSE_SECONDS=5

# --- Bench harness (Opus 4.7 comparison) -------------------------------------

# Hard budget cap in USD. The cost guard refuses any Opus call when the running
# total + projected next-call cost would exceed this number. Set to 0 to
# disable Opus calls entirely.
#
# Per Sam's directive 2026-05-05: cap is $0 until further notice.
BENCH_BUDGET_USD=0

# Anthropic API key. Only required when BENCH_BUDGET_USD > 0.
# Get one from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
